---
import { SITE, BOOK } from '../consts';

export interface Props {
  title: string;
  description?: string;
  path?: string;
  includeBookSchema?: boolean;
}

const { title, description = SITE.description, path = '/', includeBookSchema = false } = Astro.props;

const canonicalURL = new URL(path, SITE.origin).toString();
const ogImageURL = new URL(SITE.ogImage, SITE.origin).toString();

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: SITE.origin,
  logo: ogImageURL,
  sameAs: [
    'https://instagram.com/freshbeginningscommunity',
    'https://www.facebook.com/groups/360330059436123',
    'https://www.youtube.com/@freshbeginningspublishing',
  ],
};

const bookSchema = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: BOOK.title,
  author: {
    '@type': 'Person',
    name: BOOK.author,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.origin,
  },
  url: BOOK.url,
  image: ogImageURL,
  offers: {
    '@type': 'Offer',
    url: BOOK.amazonUrl,
    availability: 'https://schema.org/InStock',
  },
};
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${SITE.name} — Empowering Children through Captivating Stories`} />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- Structured data: Organization is site-wide -->
<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
{includeBookSchema && <script type="application/ld+json" set:html={JSON.stringify(bookSchema)} />}
