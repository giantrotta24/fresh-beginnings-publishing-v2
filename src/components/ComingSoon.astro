---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

{/* flex-1 centers the empty state in the leftover viewport height (main is a flex column). */}
<section class="flex flex-1 items-center py-10 md:py-16">
  <div class="mx-auto w-full max-w-2xl px-4 sm:px-6">
    <div class="flex flex-col items-center py-12 text-center md:py-20">
      <h2 class="font-display mb-6 text-4xl font-semibold leading-tight tracking-tight md:mb-10 md:text-5xl">
        {title}
      </h2>
      <svg
        viewBox="0 0 48 48"
        class="text-ochre/70 mb-6 h-12 w-12"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M6 26c1-11 8-19 18-19s17 8 18 19c-6 3-30 3-36 0Z"></path>
        <path d="M19 28.5c-1 5-.5 8.5 1.5 11.5h7c2-3 2.5-6.5 1.5-11.5"></path>
        <path d="M15.5 18.5h.01M24 13.5h.01M31.5 19.5h.01"></path>
      </svg>
      <p class="text-xl">This chapter hasn't been written yet.</p>
      <p class="text-muted mt-2">
        New stories from the forest floor are on their way — check back soon.
      </p>
    </div>
  </div>
</section>
