---
import { FOOTER_LINKS, SOCIAL } from '../data';

const year = new Date().getFullYear();

// Inline SVGs (no icon package dependency, zero client JS).
const ICONS: Record<string, string> = {
  instagram:
    'M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8 1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5 5 5 0 0 1-5 5 5 5 0 0 1-5-5 5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3z',
  facebook: 'M7 10v4h3v7h4v-7h3l1-4h-4V8a1 1 0 0 1 1-1h3V3h-3a5 5 0 0 0-5 5v2H7',
};
---

<footer class="border-t border-gray-200">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="grid grid-cols-12 gap-4 gap-y-8 py-8 sm:gap-8 md:py-12">
      <div class="col-span-12 lg:col-span-4">
        <a class="inline-block text-xl font-bold" href="/">Fresh Beginnings Publishing, LLC</a>
      </div>

      <div class="col-span-6 md:col-span-3 lg:col-span-2">
        <div class="mb-2 font-medium">Product</div>
        <ul class="text-sm">
          {
            FOOTER_LINKS.product.map((link) => (
              <li class="mb-2">
                <a class="text-muted transition duration-150 ease-in-out hover:text-gray-700 hover:underline" href={link.href}>
                  {link.text}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="col-span-6 md:col-span-3 lg:col-span-2">
        <div class="mb-2 font-medium">Company</div>
        <ul class="text-sm">
          {
            FOOTER_LINKS.company.map((link) => (
              <li class="mb-2">
                <a class="text-muted transition duration-150 ease-in-out hover:text-gray-700 hover:underline" href={link.href}>
                  {link.text}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="flex flex-col items-start justify-between gap-4 py-6 md:flex-row md:items-center md:py-8">
      <ul class="-ml-2 flex md:ml-0">
        {
          SOCIAL.map((social) => (
            <li>
              <a
                class="text-muted inline-flex items-center rounded-lg p-2.5 text-sm hover:bg-gray-100"
                aria-label={social.label}
                href={social.href}
              >
                {social.icon === 'youtube' ? (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="18" height="14" x="3" y="5" rx="4" />
                    <path d="m10 9 5 3-5 3z" />
                  </svg>
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
                    <path d={ICONS[social.icon]} />
                  </svg>
                )}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="text-muted text-sm">
        © {year} <a class="text-blue-600 hover:underline" href="https://freshbeginningspublishing.com/">Fresh Beginnings Publishing, LLC.</a> All rights reserved.
      </div>
    </div>
  </div>
</footer>
