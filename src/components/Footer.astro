---
import { FOOTER_LINKS, SOCIAL, SOCIAL_ICON_PATHS } from '../data';

const year = new Date().getFullYear();
const ICONS = SOCIAL_ICON_PATHS;
---

<footer class="border-t border-gray-200">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="grid grid-cols-12 gap-4 gap-y-8 py-8 sm:gap-8 md:py-12">
      <div class="col-span-12 lg:col-span-4">
        <a class="font-display inline-block text-xl font-semibold text-green-800" href="/">Fresh Beginnings Publishing, LLC</a>
      </div>

      <div class="col-span-6 md:col-span-3 lg:col-span-2">
        <div class="text-muted mb-3 text-xs font-semibold tracking-wider uppercase">Product</div>
        <ul class="text-sm">
          {
            FOOTER_LINKS.product.map((link) => (
              <li class="mb-2">
                <a class="text-muted decoration-ochre/60 underline-offset-4 transition-colors duration-150 hover:text-green-800 hover:underline" href={link.href}>
                  {link.text}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="col-span-6 md:col-span-3 lg:col-span-2">
        <div class="text-muted mb-3 text-xs font-semibold tracking-wider uppercase">Company</div>
        <ul class="text-sm">
          {
            FOOTER_LINKS.company.map((link) => (
              <li class="mb-2">
                <a class="text-muted decoration-ochre/60 underline-offset-4 transition-colors duration-150 hover:text-green-800 hover:underline" href={link.href}>
                  {link.text}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="flex flex-col items-start justify-between gap-4 py-6 md:flex-row md:items-center md:py-8">
      <ul class="-ml-2 flex md:ml-0">
        {
          SOCIAL.map((social) => (
            <li>
              <a
                class="text-muted hover:text-ochre inline-flex items-center rounded-lg p-2.5 text-sm transition-colors hover:bg-green-800/5"
                aria-label={social.label}
                href={social.href}
              >
                {social.icon === 'youtube' ? (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="18" height="14" x="3" y="5" rx="4" />
                    <path d="m10 9 5 3-5 3z" />
                  </svg>
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
                    <path d={ICONS[social.icon]} />
                  </svg>
                )}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="text-muted text-sm">
        © {year} <a class="decoration-ochre/60 text-green-800 underline-offset-4 hover:underline" href="https://freshbeginningspublishing.com/">Fresh Beginnings Publishing, LLC.</a> All rights reserved.
      </div>
    </div>
  </div>
</footer>
