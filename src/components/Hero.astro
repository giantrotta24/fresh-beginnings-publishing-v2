---
import { Image } from 'astro:assets';
import mushImage from '../assets/images/mush.png';
---

<section class="relative">
  <div class="mx-auto max-w-7xl px-4 sm:px-6">
    <div class="py-12 md:py-20 lg:flex lg:items-center lg:justify-around lg:gap-8 lg:py-24">
      <div class="mx-auto pb-10 text-center md:pb-16 lg:mx-0 lg:max-w-xl lg:text-left">
        <h1 class="mb-4 text-5xl font-bold leading-tight tracking-tight md:text-6xl">
          Welcome to <span class="text-green-800">Fresh Beginnings</span> Publishing
        </h1>
        <div class="mx-auto max-w-3xl lg:mx-0">
          <p class="text-muted mb-6 text-xl">Empowering Children through Captivating Stories</p>
        </div>
      </div>
      <div>
        <div class="relative mx-auto max-w-lg">
          <Image
            src={mushImage}
            alt="Mushroom Hero Image"
            widths={[400, 768, 1024, 1080]}
            sizes="(max-width: 767px) 400px, (max-width: 1023px) 768px, 1024px"
            class="mx-auto w-full rounded-md"
            loading="eager"
            format="webp"
          />
        </div>
      </div>
    </div>
  </div>
</section>
