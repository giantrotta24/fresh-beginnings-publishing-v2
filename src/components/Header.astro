---
// Zero-JS nav: the mobile menu uses the checkbox/peer CSS pattern instead of a
// script-driven toggle. The "Our work" submenu uses the same checkbox pattern so
// a tap toggles it on touch devices at desktop widths (iPads hit the md: nav but
// never hover); pointer hover still opens it, and the checkbox keeps it
// keyboard-reachable. Below md it stays flattened (always visible) in the
// stacked menu.
import { NAV_LINKS } from '../data';

const navLinkClass =
  'relative px-4 py-3 font-bold text-green-800 transition-colors hover:text-green-600 after:absolute after:inset-x-4 after:bottom-1.5 after:h-[2px] after:origin-left after:scale-x-0 after:rounded-full after:bg-ochre after:transition-transform after:duration-200 hover:after:scale-x-100 motion-reduce:after:transition-none';
---

<header class="sticky top-0 z-40 w-full border-b border-green-800/10 bg-[rgb(245,255,250)]">
  <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between px-4 py-3 md:flex-nowrap md:px-6">
    <a class="font-display self-center whitespace-nowrap text-xl font-semibold text-green-800 md:text-2xl" href="/">
      Fresh Beginnings
    </a>

    <input type="checkbox" id="nav-toggle" class="peer hidden" />
    <label
      for="nav-toggle"
      class="cursor-pointer rounded-lg p-2.5 text-green-800 hover:bg-gray-100 md:hidden"
      aria-label="Toggle menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 8h16" /><path d="M4 16h16" />
      </svg>
    </label>

    <nav
      aria-label="Main navigation"
      class="order-last hidden w-full basis-full flex-col gap-1 py-2 peer-checked:flex md:order-none md:flex md:w-auto md:basis-auto md:flex-row md:items-center md:py-0"
    >
      {
        NAV_LINKS.map((link) => {
          if (!('links' in link && link.links)) {
            return (
              <a class={navLinkClass} href={link.href}>
                {link.text}
              </a>
            );
          }
          const menuId = `nav-${link.text.toLowerCase().replace(/\s+/g, '-')}`;
          return (
            <div class="group relative">
              <input type="checkbox" id={menuId} class="peer sr-only" />
              <label
                for={menuId}
                class={`${navLinkClass} flex cursor-pointer items-center gap-1 peer-focus-visible:outline-2 peer-focus-visible:outline-green-800 peer-focus-visible:outline-offset-[3px]`}
              >
                {link.text}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="hidden h-3.5 w-3.5 md:inline" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </label>
              <div class="pl-4 md:absolute md:z-50 md:hidden md:min-w-[200px] md:rounded-lg md:border md:border-green-800/10 md:bg-[rgb(245,255,250)] md:py-1 md:pl-0 md:shadow-[0_1px_2px_rgba(17,17,17,0.05),0_6px_16px_rgba(17,17,17,0.06)] md:group-hover:block md:peer-checked:block">
                {link.links.map((sub) => (
                  <a class="block px-4 py-2 text-sm text-green-800 transition-colors hover:bg-green-800/5 hover:text-green-600 md:whitespace-nowrap" href={sub.href}>
                    {sub.text}
                  </a>
                ))}
              </div>
            </div>
          );
        })
      }
    </nav>
  </div>
</header>
