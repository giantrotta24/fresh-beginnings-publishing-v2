---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { CONTACT_EMAIL, SOCIAL_LINKS } from '../consts';
import { SOCIAL_ICON_PATHS } from '../data';
import mushImage from '../assets/images/mush.png';
---

<Layout
  title="Contact | Fresh Beginnings Publishing"
  description="Get in touch with Fresh Beginnings Publishing, publisher of Rusty the Raccoon is Scared of the Dark."
  path="/contact"
>
  {/* flex-1 centers the page in the leftover viewport height (main is a flex column). */}
  <section class="flex flex-1 items-center py-10 md:py-16">
    <div class="mx-auto w-full max-w-2xl px-4 sm:px-6">
      <div class="flex flex-col items-center py-12 text-center md:py-16">
        <div class="wiggle-group relative mb-10 w-full max-w-[240px]">
          {/* Same forest-floor shape as the hero, tilted the other way so the two pages rhyme without repeating. */}
          <svg
            class="absolute inset-0 h-full w-full text-[#ddeee3]"
            viewBox="0 0 200 200"
            aria-hidden="true"
          >
            <path
              fill="#b07a24"
              opacity="0.1"
              transform="translate(94,108) rotate(20) scale(1.02,0.88)"
              d="M45.7,-58.9C58.9,-49.5,68.9,-35.3,72.9,-19.4C76.9,-3.5,74.8,14.1,66.6,27.6C58.4,41.1,44.1,50.6,29.2,57.4C14.3,64.1,-1.2,68.2,-16.9,65.4C-32.7,62.6,-48.6,53,-58.1,39.2C-67.6,25.4,-70.6,7.4,-67.4,-9.1C-64.2,-25.6,-54.7,-40.7,-41.8,-50.2C-28.9,-59.7,-12.4,-63.6,2.5,-66.7C17.5,-69.8,35,-72,45.7,-58.9Z"
            />
            <path
              fill="currentColor"
              transform="translate(100,100) rotate(16) scale(1.04,0.9)"
              d="M45.7,-58.9C58.9,-49.5,68.9,-35.3,72.9,-19.4C76.9,-3.5,74.8,14.1,66.6,27.6C58.4,41.1,44.1,50.6,29.2,57.4C14.3,64.1,-1.2,68.2,-16.9,65.4C-32.7,62.6,-48.6,53,-58.1,39.2C-67.6,25.4,-70.6,7.4,-67.4,-9.1C-64.2,-25.6,-54.7,-40.7,-41.8,-50.2C-28.9,-59.7,-12.4,-63.6,2.5,-66.7C17.5,-69.8,35,-72,45.7,-58.9Z"
            />
          </svg>
          <Image
            src={mushImage}
            alt=""
            widths={[240, 480]}
            sizes="240px"
            class="wiggle-item relative mx-auto w-full"
            format="webp"
          />
        </div>

        <h1 class="font-display mb-4 text-4xl font-semibold leading-tight tracking-tight md:text-5xl">
          Contact us
        </h1>
        <p class="max-w-lg text-xl">
          Whether you have a question about our books, a note for Rusty's author, or just want to
          say hello — we'd love to hear from you.
        </p>

        {/* Fluid font size: the email is one long unbreakable word, so the
            button text scales down on narrow phones (12px at 320px) instead of
            overflowing full-bleed; caps at the shared button size from ~420px up. */}
        <a
          class="mt-8 inline-block rounded-lg bg-green-800 px-6 py-3 text-[clamp(0.75rem,3.8vw,1rem)] font-bold text-[rgb(245,255,250)] transition hover:-translate-y-px hover:bg-green-700 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
          href={`mailto:${CONTACT_EMAIL}`}
        >
          {CONTACT_EMAIL}
        </a>

        <p class="text-muted mt-12 mb-4 text-sm font-semibold tracking-wider uppercase">
          Or find us here
        </p>
        <ul class="flex items-center gap-2">
          {
            SOCIAL_LINKS.map((social) => (
              <li>
                <a
                  class="text-muted hover:text-ochre inline-flex items-center rounded-lg p-3 transition-colors hover:bg-green-800/5"
                  aria-label={social.label}
                  href={social.href}
                >
                  {social.icon === 'youtube' ? (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect width="18" height="14" x="3" y="5" rx="4" />
                      <path d="m10 9 5 3-5 3z" />
                    </svg>
                  ) : (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor">
                      <path d={SOCIAL_ICON_PATHS[social.icon]} />
                    </svg>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>
</Layout>
