---
import Layout from '../layouts/Layout.astro';
import { CONTACT_EMAIL } from '../consts';
---

<Layout
  title="Contact | Fresh Beginnings Publishing"
  description="Get in touch with Fresh Beginnings Publishing, publisher of Rusty the Raccoon is Scared of the Dark."
  path="/contact"
>
  <section class="py-10 md:py-16">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <div class="flex flex-col items-center py-12 text-center md:py-20">
        <h2 class="mb-4 text-4xl font-bold leading-tight tracking-tight md:mb-8 md:text-5xl">Contact us</h2>
        <div class="text-muted flex flex-wrap items-center justify-center gap-2 text-xl">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
            <path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2m0 4-8 5-8-5V6l8 5 8-5z" />
          </svg>
          <p>Email us at</p>
          <a class="text-blue-600 hover:underline" href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
