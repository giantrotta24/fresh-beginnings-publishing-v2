---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import rustyLogImage from '../assets/images/rusty-log.png';
---

<Layout
  title="Page not found | Fresh Beginnings Publishing"
  description="This page wandered off the path. Head back to Fresh Beginnings Publishing, publisher of Rusty the Raccoon is Scared of the Dark."
  path="/404"
>
  <section class="py-10 md:py-16">
    <div class="mx-auto max-w-2xl px-4 sm:px-6">
      <div class="flex flex-col items-center py-12 text-center md:py-16">
        <p class="font-display text-ochre mb-2 text-xl font-semibold">404</p>
        <h1 class="font-display mb-6 text-4xl font-semibold leading-tight tracking-tight md:text-5xl">
          This page wandered off the path.
        </h1>
        <Image
          src={rustyLogImage}
          alt="Rusty the Raccoon peeking over a log"
          widths={[320, 640]}
          sizes="320px"
          class="mb-8 w-full max-w-xs"
          format="webp"
        />
        <p class="text-xl">Even brave explorers lose their way in the dark sometimes.</p>
        <p class="text-muted mt-2">
          Let's head back to familiar ground — or say hello if you think something's missing.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
          <a
            class="decoration-ochre font-bold text-green-800 underline-offset-4 transition-colors hover:text-green-600 hover:underline"
            href="/"
          >
            Back to the homepage
          </a>
          <a
            class="decoration-ochre/60 text-muted underline-offset-4 transition-colors hover:text-green-800 hover:underline"
            href="/contact"
          >
            Contact us
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
